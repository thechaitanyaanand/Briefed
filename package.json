{
  "name": "briefed-cli",
  "version": "0.9.1",
  "description": "AI-powered git context synchronizer — auto-updates CLAUDE.md, AGENTS.md, and AI context files after every git pull or merge",
  "author": "Chaitanya Anand",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thechaitanyaanand/Briefed.git"
  },
  "homepage": "https://thechaitanyaanand.github.io/Briefed",
  "keywords": [
    "ai",
    "context",
    "git",
    "claude",
    "cursor",
    "copilot",
    "llm",
    "developer-tools",
    "git-hooks",
    "ai-context",
    "briefed"
  ],
  "type": "module",
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "bin": {
    "briefed": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "minimatch": "^9.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
